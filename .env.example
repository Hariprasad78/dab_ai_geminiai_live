# Vertex AI / Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
VERTEX_PLANNER_MODEL=gemini-2.5-flash
VERTEX_LIVE_MODEL=gemini-2.0-flash-live-preview-04-09

# LiveKit
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
ENABLE_LIVEKIT_AGENT=false

# DAB (Device Automation Bus)
# Set to "false" to connect to a real MQTT broker
DAB_MOCK_MODE=false
DAB_MQTT_BROKER=localhost
DAB_MQTT_PORT=1883
DAB_DEVICE_ID=adt-4
DAB_REQUEST_TIMEOUT=2
DAB_MAX_RETRIES=3

# Session
SESSION_TIMEOUT_SECONDS=300
MAX_STEPS_PER_RUN=50

# Artifacts
ARTIFACTS_BASE_DIR=./artifacts

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO

# Multi-camera FastAPI preview service
# Format: device_id|kind|locator[|required-or-optional];...
# locator supports:
#   /dev/videoN
#   by-id:/dev/v4l/by-id/<stable-symlink>
#   usb:<substring-from-/dev/v4l/by-id>
MULTI_CAMERA_DEVICES=cam1|camera|by-id:/dev/v4l/by-id/usb-Logitech_C920-video-index0;cam2|camera|by-id:/dev/v4l/by-id/usb-Logitech_C922-video-index0;hdmi|hdmi|usb:elgato
MULTI_CAMERA_HOST=0.0.0.0
MULTI_CAMERA_PORT=8090
MULTI_CAMERA_LOG_LEVEL=INFO
MULTI_CAMERA_WIDTH=1280
MULTI_CAMERA_HEIGHT=720
MULTI_CAMERA_FPS=30.0
MULTI_CAMERA_JPEG_QUALITY=85
MULTI_CAMERA_FOURCC=MJPG
MULTI_CAMERA_RECONNECT_SECONDS=2.0
MULTI_CAMERA_STARTUP_TIMEOUT_SECONDS=8.0
MULTI_CAMERA_OPEN_RETRIES=4
MULTI_CAMERA_OPEN_RETRY_DELAY_SECONDS=0.6
MULTI_CAMERA_STALE_FRAME_SECONDS=5.0
MULTI_CAMERA_MONITOR_INTERVAL_SECONDS=2.0

# WebRTC camera preview service
# Format: device_id|kind|locator[|required-or-optional];...
# locator supports:
#   /dev/videoN
#   by-id:/dev/v4l/by-id/<stable-symlink>
#   usb:<substring-from-/dev/v4l/by-id>
#   auto:camera1 / auto:camera2 / auto:hdmi
WEBRTC_CAMERA_DEVICES=cam1|camera|auto:camera1|optional;cam2|camera|auto:camera2|optional;hdmi|hdmi|auto:hdmi|optional
WEBRTC_CAMERA_HOST=0.0.0.0
WEBRTC_CAMERA_PORT=8080
WEBRTC_CAMERA_LOG_LEVEL=INFO
WEBRTC_CAMERA_WIDTH=1280
WEBRTC_CAMERA_HEIGHT=720
WEBRTC_CAMERA_FPS=30.0
WEBRTC_CAMERA_FOURCC=MJPG
WEBRTC_CAMERA_OPEN_RETRIES=4
WEBRTC_CAMERA_OPEN_RETRY_DELAY_SECONDS=0.5
WEBRTC_CAMERA_RECONNECT_SECONDS=2.0
WEBRTC_CAMERA_FRAME_TIMEOUT_SECONDS=5.0
WEBRTC_CAMERA_STARTUP_TIMEOUT_SECONDS=8.0
WEBRTC_CAMERA_STATUS_INTERVAL_SECONDS=1.0
WEBRTC_CAMERA_STUN_URLS=stun:stun.l.google.com:19302
