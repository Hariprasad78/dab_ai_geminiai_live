# Vertex AI / Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=asia-south1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
VERTEX_LIVE_MODEL=gemini-2.0-flash-live-preview-04-09

# LiveKit
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret

# DAB (Device Automation Bus)
# Set to "false" to connect to a real MQTT broker
DAB_MOCK_MODE=true
DAB_MQTT_BROKER=localhost
DAB_MQTT_PORT=1883
DAB_DEVICE_ID=mock-device
DAB_REQUEST_TIMEOUT=10.0
DAB_MAX_RETRIES=3

# Session
SESSION_TIMEOUT_SECONDS=300
MAX_STEPS_PER_RUN=50

# Artifacts
ARTIFACTS_BASE_DIR=./artifacts

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# Logging (DEBUG / INFO / WARNING / ERROR)
LOG_LEVEL=INFO
